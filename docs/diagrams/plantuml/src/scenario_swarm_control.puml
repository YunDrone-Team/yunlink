@startuml
title 场景：地面站控制 UAV 集群
skinparam backgroundColor white
skinparam shadowing false

actor "Ground Station" as GS
participant "Swarm Endpoint" as SW
participant "Group Executor" as GX
participant "UAV-A" as A
participant "UAV-B" as B

GS -> SW : SessionHello / Authenticate /\nCapabilities / Ready
SW --> GS : Session 进入 Active

GS -> SW : AuthorityRequest(Claim)\ntarget = Group(UAV, group_id=42)
SW --> GS : Group authority granted

GS -> SW : Command.FormationTask\n(target.group_id = 42)
SW --> GS : CommandResult.Received
SW --> GS : CommandResult.Accepted
SW -> GX : 执行群组任务
GX -> A : fan-out 子任务
GX -> B : fan-out 子任务
A --> SW : StateSnapshot / Event
B --> SW : StateSnapshot / Event
SW --> GS : Group CommandResult.InProgress
SW --> GS : 成员状态/事件回流
SW --> GS : Group CommandResult.Succeeded\n或 Failed
@enduml
